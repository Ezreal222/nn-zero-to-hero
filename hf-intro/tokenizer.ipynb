   "source": [
    "from transformers import AutoTokenizer\n",
    "tok = AutoTokenizer.from_pretrained(\"gpt2\")\n",
    "s = \"Tokenization is sneaky: 12345 and  spaces.\"\n",
    "ids = tok.encode(s)\n",
    "print(\"token 数:\", len(ids))\n",
    "print(\"ids:\", ids)\n",
    "print(\"还原:\", tok.decode(ids))\n",
    "print(\"逐 token:\", [tok.decode([i]) for i in ids])"
   ]
  }
 ],
